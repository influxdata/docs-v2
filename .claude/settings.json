{
  "permissions": {
    "allow": [
      "Bash(link-checker:*)",
      "Bash(pkill:*)",
      "Bash(pgrep:*)",
      "Bash(ps:*)",
      "Bash(lsof:*)",
      "Bash(kill:*)",
      "Bash(timeout:*)",
      "Bash(trash:*)",
      "Bash(stat:*)",
      "Bash(.ci/vale/vale.sh:*)",
      "Bash(.ci/shellcheck/shellcheck.sh:*)",
      "Bash(shellcheck:*)",
      "Bash(npm:*)",
      "Bash(yarn:*)",
      "Bash(pnpm:*)",
      "Bash(npx:*)",
      "Bash(node:*)",
      "Bash(python:*)",
      "Bash(python3:*)",
      "Bash(pip:*)",
      "Bash(poetry:*)",
      "Bash(make:*)",
      "Bash(cargo:*)",
      "Bash(go:*)",
      "Bash(curl:*)",
      "Bash(gh:*)",
      "Bash(hugo:*)",
      "Bash(htmlq:*)",
      "Bash(jq:*)",
      "Bash(yq:*)",
      "Bash(mkdir:*)",
      "Bash(cat:*)",
      "Bash(ls:*)",
      "Bash(echo:*)",
      "Bash(rg:*)",
      "Bash(grep:*)",
      "Bash(find:*)",
      "Bash(bash:*)",
      "Bash(wc:*)",
      "Bash(sort:*)",
      "Bash(uniq:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(awk:*)",
      "Bash(touch:*)",
      "Bash(docker:*)",
      "Bash(git:*)",
      "Bash(fzf:*)",
      "Bash(sleep:*)",
      "Bash(date:*)",
      "Bash(cp:*)",
      "Bash(mv:*)",
      "Bash(chmod:*)",
      "Bash(diff:*)",
      "Bash(tr:*)",
      "Bash(cut:*)",
      "Bash(sed:*)",
      "Bash(tee:*)",
      "Bash(xargs:*)",
      "Edit",
      "Read",
      "Write",
      "Grep",
      "Glob",
      "LS",
      "Skill(superpowers:brainstorming)",
      "Skill(superpowers:brainstorming:*)",
      "mcp__acp__Bash",
      "mcp__github__pull_request_read"
    ],
    "deny": [
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(./secrets/**)",
      "Read(./config/credentials.json)",
      "Read(./build)",
      "Read(**/.env)",
      "Read(**/.env.*)",
      "Read(~/.ssh/**)",
      "Read(~/.aws/**)",
      "Read(~/.gnupg/**)",
      "Read(~/.config/gh/hosts.yml)",
      "Read(~/.netrc)",
      "Read(~/.npmrc)",
      "Read(~/.pypirc)",
      "Read(~/.git-credentials)",
      "Read(~/**/*.pem)",
      "Read(~/**/*.key)",
      "Read(~/**/*.p12)",
      "Read(~/**/*.pfx)"
    ],
    "ask": [
      "Bash(git push:*)",
      "Bash(rm:*)",
      "Read(/tmp)",
      "Bash(git reset --hard:*)",
      "Bash(git clean:*)",
      "Bash(git rebase:*)",
      "Bash(sudo:*)",
      "Bash(dd:*)",
      "Bash(shred:*)",
      "Bash(mkfs:*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Read|Glob|Grep",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/check-worktree-paths.sh",
            "timeout": 5,
            "statusMessage": "Checking worktree path safety"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/check-bash-worktree.sh",
            "timeout": 5,
            "statusMessage": "Checking worktree path safety"
          }
        ]
      },
      {
        "matcher": "WebFetch|WebSearch",
        "hooks": [
          {
            "type": "prompt",
            "prompt": "If this WebFetch or WebSearch is being used to search for or read content that exists in this repository (documentation pages, markdown files, frontmatter, shortcodes, Hugo templates), REJECT — use Grep, Glob, or Read for local content. Only allow WebFetch/WebSearch for truly external resources: GitHub issues/PRs, external APIs, third-party documentation, or URLs the user explicitly provided.",
            "statusMessage": "Checking local-first search"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Grep|Glob",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/suggest-shared-content.sh",
            "timeout": 5
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/session-start.sh",
            "timeout": 300,
            "statusMessage": "Installing dependencies and lint toolchain"
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/sync-worktree-deps.sh",
            "timeout": 300,
            "async": true,
            "statusMessage": "Syncing worktree dependencies"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/worktree-context.sh",
            "timeout": 5
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "github@claude-plugins-official": true
  },
  "worktree": {
    "symlinkDirectories": ["node_modules", ".cache"]
  }
}
